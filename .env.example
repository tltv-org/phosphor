# Phosphor environment variables
#
# These are only used during development (npm run dev).
# In production, phosphor is served from the same origin as cathode's
# nginx, so location.host is the TLTV node automatically.

# Home TLTV node — used as default hint for channel resolution.
# Set this to your cathode dev stack's nginx-rtmp address.
# VITE_TLTV_NODE=localhost:8888
